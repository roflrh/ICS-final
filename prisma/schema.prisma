// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  orders       Order[]

  @@map("users")
}

model Restaurant {
  id              String   @id @default(uuid())
  name            String
  description     String
  imageUrl        String
  category        String
  rating          Float?   @default(4.5)   // 신규 식당에 대한 평점 미누적 상태(null) 지원
  reviewCount     Int?     @default(0)     // 누적 리뷰 수
  deliveryTimeMin Int?     @default(20)    // 배달 예상 시간 최소 범위 (분)
  deliveryTimeMax Int?     @default(35)    // 배달 예상 시간 최대 범위 (분)
  isFastDelivery  Boolean  @default(false) // 한집배달(빠른배달) 가용 여부
  createdAt       DateTime @default(now())
  menus           Menu[]

  @@map("restaurants")
}

model Menu {
  id           String      @id @default(uuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  description  String
  price        Int
  imageUrl     String
  isPopular    Boolean     @default(false) // 사장님 추천 인기 메뉴 마킹 (왕관용)
  createdAt    DateTime    @default(now())
  orderItems   OrderItem[]

  @@map("menus")
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          String      // "PENDING" | "PREPARING" | "DELIVERING" | "COMPLETED"
  totalPrice      Int
  address         String
  riderRequest    String?     // 배달기사 요청사항 (선택 입력사항)
  shopRequest     String?     // 가게 요청사항 (선택 입력사항)
  createdAt       DateTime    @default(now())
  orderItems      OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuId    String
  menu      Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  quantity  Int
  price     Int      // 주문 당시 메뉴 가격 보존
  createdAt DateTime @default(now())

  @@map("order_items")
}
